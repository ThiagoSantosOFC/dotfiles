#!/bin/bash
MONITOR=$(XDG_RUNTIME_DIR=/run/user/1000 WAYLAND_DISPLAY=wayland-1 hyprctl monitors -j | jq -r '.[] | select(.focused) | .name')
CURRENT=$(cat /tmp/nwg-dock-monitor 2>/dev/null)
STATE=$(cat /tmp/nwg-dock-state 2>/dev/null)
PID=$(pgrep -fo nwg-dock-hyprland)

if [ -n "$PID" ] && [ "$MONITOR" = "$CURRENT" ]; then
    if [ "$STATE" = "visible" ]; then
        kill -37 "$PID"
        echo "hidden" > /tmp/nwg-dock-state
    else
        kill -36 "$PID"
        echo "visible" > /tmp/nwg-dock-state
    fi
else
    pkill -fo nwg-dock-hyprland 2>/dev/null
    while pgrep -fo nwg-dock-hyprland > /dev/null; do sleep 0.05; done
    rm -f /tmp/nwg-dock-*.lock 2>/dev/null
    echo "$MONITOR" > /tmp/nwg-dock-monitor
    echo "visible" > /tmp/nwg-dock-state
    XDG_RUNTIME_DIR=/run/user/1000 WAYLAND_DISPLAY=wayland-1 \
        nwg-dock-hyprland -p right -o "$MONITOR" -i 48 -r -nolauncher &
fi
